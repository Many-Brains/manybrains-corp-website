---
const cards = [
  {
    title: 'Shared specialist teams',
    body: 'Strategy, engineering, design, marketing, customer service, and finance run as shared services across the entire portfolio — every company draws on the same senior bench.',
  },
  {
    title: 'One stack, one playbook',
    body: 'A common technology stack and operating model, accelerated by AI, means each new business starts from a proven foundation instead of a blank page.',
  },
  {
    title: 'Validate, then scale',
    body: 'We build end to end and go to market quickly. Traction decides what comes next — we invest behind what works and table what doesn\'t.',
  },
];
---
<section id="approach" class="py-28 px-6 bg-bg-surface">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-center">How we work</h2>
    <p class="text-white/50 text-center max-w-[640px] mx-auto mt-4">
      One operating model across every business.
    </p>
    <div class="grid md:grid-cols-3 gap-6 mt-14">
      {cards.map((c) => (
        <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-7">
          <h3 class="text-lg font-semibold text-accent">{c.title}</h3>
          <p class="text-white/60 leading-relaxed mt-3 text-[15px]">{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
