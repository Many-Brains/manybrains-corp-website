---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Approach from '../components/Approach.astro';
import Portfolio from '../components/Portfolio.astro';
import Partner from '../components/Partner.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Many Brains, Inc. — A venture studio, built by many brains." description="Many Brains is a venture studio. A small team and shared specialist services build businesses end to end, validate them in market, and scale what works — across our own ventures and select partner projects." path="/">
  <Nav />
  <main>
    <Hero />
    <Approach />
    <Portfolio />
    <Partner />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
